# Telegram API credentials
# Получить можно на https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash

# Telegram phone number (с кодом страны, например +79991234567)
PHONE=+79991234567

# ID или username канала, из которого парсим посты (например: @channelname или -100123456789)
SOURCE_CHANNEL=@source_channel

# ID или username вашего канала, куда публикуем посты (например: @channelname или -100123456789)
TARGET_CHANNEL=@target_channel

# Интервал проверки новых постов (в секундах)
# Для быстрой реакции на алерты рекомендуется 30-60 секунд
CHECK_INTERVAL=30

# Случайные задержки для безопасности (имитация человеческого поведения)
RANDOM_DELAY=true
DELAY_VARIANCE=5  # Случайная задержка ±5 секунд (25-35 сек при CHECK_INTERVAL=30)

# Пути к файлам с ключевыми фразами (по одной фразе на строку)
KEYWORDS_ALERT_FILE=data/keywords_alert.txt  # Фразы о начале тревоги
KEYWORDS_CLEAR_FILE=data/keywords_clear.txt  # Фразы об отбое тревоги

# Текст шаблона для сообщений о ТРЕВОГЕ
# Используйте \n для переноса строк
# Поддерживается HTML форматирование: <b>жирный</b>, <i>курсив</i>
ALERT_TEMPLATE=⚡⚡⚡ <b>ВНИМАНИЕ ВСЕМ! Воздушная тревога!</b> ⚡⚡⚡

# Текст шаблона для сообщений об ОТБОЕ
# Используйте \n для переноса строк
# Поддерживается HTML форматирование: <b>жирный</b>, <i>курсив</i>
CLEAR_TEMPLATE=✅✅✅ <b>Отбой воздушной тревоги!</b> ✅✅✅

# ГИБРИДНЫЙ РЕЖИМ (опционально, для максимальной безопасности):
# Если указать BOT_TOKEN, публикация будет через Bot API (безопаснее)
# Userbot только читает, классический бот только публикует
# Оставьте пустым, если хотите публиковать через userbot
BOT_TOKEN=your_bot_token_here
